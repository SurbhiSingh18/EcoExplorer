<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8F5E9"
    android:padding="20dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Title -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Eco Travel Tips"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_marginBottom="20dp" />

        <!-- Best Time -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌤 Best Time to Visit"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#2E7D32" />

        <TextView
            android:id="@+id/bestTimeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:layout_marginBottom="20dp"
            android:textColor="#1B5E20" />

        <!-- First Timers -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✨ First-Time Visitors"
            android:textSize="20sp"
            android:textColor="#2E7D32"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/firstTimersText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:layout_marginBottom="20dp" />

        <!-- Experienced -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌿 Experienced Visitors"
            android:textSize="20sp"
            android:textColor="#2E7D32"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/experiencedText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:layout_marginBottom="20dp" />

        <!-- Packing -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎒 Packing Checklist"
            android:textSize="20sp"
            android:textColor="#2E7D32"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/packingText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:layout_marginBottom="20dp" />

        <!-- Dos and Don'ts -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ Do’s And Don’ts"
            android:textSize="20sp"
            android:textColor="#2E7D32"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dosDontsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:layout_marginBottom="30dp" />

        <!-- Row of two buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btnBackToSummary"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Back to Summary"
                android:backgroundTint="#388E3C"
                android:textColor="@android:color/white" />

            <Button
                android:id="@+id/btnGoToPlanner"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Go to Planner"
                android:backgroundTint="#2E7D32"
                android:textColor="@android:color/white"
                android:layout_marginStart="12dp" />

        </LinearLayout>

        <!-- FULL WIDTH PLANNER BUTTON -->
        <Button
            android:id="@+id/btnGoHome"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="🏠 Home"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#1B5E20"
            android:layout_marginTop="20dp" />

    </LinearLayout>

</ScrollView>
