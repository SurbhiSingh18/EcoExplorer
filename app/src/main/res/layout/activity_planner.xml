<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E8F5E9">

    <!-- 🌿 Custom Navigation Bar -->
    <LinearLayout
        android:id="@+id/navBar"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:background="#2E7D32"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <!-- ✅ Enlarged touch area using FrameLayout -->

        <ImageView
            android:id="@+id/btnBackHome"
            android:layout_width="70dp"
            android:layout_height="54dp"
            android:clickable="true"
            android:contentDescription="Back"
            android:focusable="true"
            android:src="@drawable/ic_arrow_back"
            app:tint="@android:color/white" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="       GreenPath Planner 🌿"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>


    <!-- 🌿 Main Planner Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Plan Your Eco Trip 🌱"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/etBudget"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#4CAF50"
            android:hint="Enter your budget (₹)"
            android:inputType="number" />

        <Spinner
            android:id="@+id/spinnerActivity"
            android:layout_width="match_parent"
            android:layout_height="53dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#4CAF50"
            android:spinnerMode="dropdown" />

        <Button
            android:id="@+id/btnGetSuggestions"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:backgroundTint="#388E3C"
            android:text="Get Eco Suggestions"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</LinearLayout>
